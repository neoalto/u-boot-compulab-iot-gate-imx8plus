boot_fdt=try
boot_fit=no
boot_targets=mmc2
bootm_size=0x10000000
console=ttymxc1,115200 earlycon=ec_imx6q,0x30890000,115200
fdt_addr_r=0x43000000
fdt_addr=0x43000000
fdtfile=CONFIG_DEFAULT_FDT_FILE
image=Image
kernel_addr_r=CONFIG_SYS_LOAD_ADDR
loadaddr=CONFIG_SYS_LOAD_ADDR
mmcdev=CONFIG_ENV_MMC_DEVICE_INDEX
mmcpart=1
mmcroot=/dev/mmcblk2p2 rootwait rw
finduuid=part uuid mmc ${mmcdev}:2 uuid
mmcargs=if run finduuid; then setenv mmcroot PARTUUID=${uuid} rootwait rw; fi; setenv bootargs console=${console} root=${mmcroot}
loadimage=fatload mmc ${mmcdev}:${mmcpart} ${loadaddr} ${image}
loadfdt=fatload mmc ${mmcdev}:${mmcpart} ${fdt_addr_r} ${fdtfile}
mmcboot=echo Booting from eMMC ...;
	run mmcargs;
	if test ${boot_fit} = yes || test ${boot_fit} = try; then
		bootm ${loadaddr};
	else
		if run loadfdt; then
			booti ${loadaddr} - ${fdt_addr_r};
		else
			echo WARN: Cannot load the DT;
		fi;
	fi
bsp_bootcmd=echo Running eMMC-only BSP bootcmd ...;
	mmc dev ${mmcdev};
	if run loadimage; then
		run mmcboot;
	else
		echo WARN: Cannot load ${image} from eMMC;
	fi
