/* SPDX-License-Identifier: (GPL-2.0+ OR MIT) */

/*
 * Robust eMMC A/B boot policy for IOT-GATE-IMX8PLUS.
 *
 * This file is converted into U-Boot's compiled default environment.
 * Keep policy here immutable and keep persistent state small.
 */

/* Main entry points. bootlimit uses altbootcmd after repeated trial failures. */
bootcmd=run ab_boot
altbootcmd=run ab_rollback

/* Immutable board identity. Do not set these from C when env write-list is used. */
board_name=IOT-GATE-IMX8PLUS
board_rev=D2

/* Immutable BSP defaults retained from the original board environment. */
boot_fdt=try
boot_fit=no
boot_targets=mmc2
bootm_size=0x10000000
bootlimit=3

/* Linux console: uart2 is exposed as ttymxc0 by the kernel on this DT. */
console=ttymxc0,115200
earlycon=earlycon=ec_imx6q,0x30890000,115200

/* Keep the DTB above the relocated Image range. booti moves Image to
 * roughly 0x40600000..0x43760000 on the 6.18 kernel observed here, so
 * 0x43000000 is unsafe and gets clobbered.
 */
fdt_addr_r=0x48000000
fdt_addr=0x48000000
fdtfile=iot-gate-imx8plus.dtb

image=Image
kernel_addr_r=CONFIG_SYS_LOAD_ADDR
loadaddr=CONFIG_SYS_LOAD_ADDR

mmcdev=CONFIG_ENV_MMC_DEVICE_INDEX
mmcpart=1
mmcroot=/dev/mmcblk2p2 rootwait rw

/*
 * Mutable A/B state.
 *
 * boot_slot is the logical slot selected for the next boot.
 * upgrade_available gates CONFIG_BOOTCOUNT_ENV: bootcount is only persisted
 * while this is 1. Linux must clear it after a successful health commit.
 * ustate/recovery_status are left for SWUpdate/user space state tracking.
 */
boot_slot=A
upgrade_available=0
bootcount=0
ustate=0
recovery_status=

/* Rollout switch for the U-Boot-to-Linux hardware watchdog handoff. */
boot_watchdog=0

/* Persistent diagnostics. These are best effort and must never block booting. */
ab_fail_count=0
ab_config_fail_count=0
ab_last_error=none
ab_last_slot=none
ab_env_health=unknown

/*
 * Original single-slot BSP boot path, kept as a last-resort fallback.
 * On the planned A/B GPT layout this normally corresponds to BOOT_A/ROOTFS_A
 * only if BOOT_A is mmcpart=1 and ROOTFS_A is partition 2.
 */
finduuid=part uuid mmc ${mmcdev}:2 uuid

mmcargs=
    if run finduuid; then
        setenv mmcroot PARTUUID=${uuid} rootwait rw;
    else
        setenv mmcroot /dev/mmcblk2p2 rootwait rw;
    fi;
    setenv bootargs console=${console} ${earlycon} root=${mmcroot} net.ifnames=0

loadimage=load mmc ${mmcdev}:${mmcpart} ${loadaddr} ${image}
loadfdt=load mmc ${mmcdev}:${mmcpart} ${fdt_addr_r} ${fdtfile}

mmcboot=
    echo Booting fixed single-slot eMMC fallback ...;
    run mmcargs;
    if run loadfdt; then
        booti ${loadaddr} - ${fdt_addr_r};
        echo WARN: fallback booti returned;
        test 1 = 0;
    else
        echo WARN: Cannot load fallback DT ${fdtfile};
        test 1 = 0;
    fi

bsp_bootcmd=
    echo Running fixed single-slot BSP bootcmd ...;
    if mmc dev ${mmcdev}; then
        if run loadimage; then
            run mmcboot;
        else
            echo WARN: Cannot load fallback ${image} from eMMC;
            test 1 = 0;
        fi;
    else
        echo WARN: Cannot select mmc ${mmcdev};
        test 1 = 0;
    fi

/* Persist a generic boot failure. */
ab_note_failure=
    echo WARN: A/B failure: ${ab_last_error} slot=${slot};
    setenv ab_last_slot ${slot};
    setexpr ab_fail_count ${ab_fail_count} + 1 || setenv ab_fail_count 1;
    saveenv

/* Persist a configuration/layout/read failure, then count it as a boot failure. */
ab_note_config_failure=
    setexpr ab_config_fail_count ${ab_config_fail_count} + 1 || setenv ab_config_fail_count 1;
    run ab_note_failure

/* Normalize boot_slot. Invalid state falls back to slot A and is persisted. */
ab_select=
    if test "${boot_slot}" = "A"; then
        setenv slot A;
    else
        if test "${boot_slot}" = "B"; then
            setenv slot B;
        else
            echo WARN: Invalid boot_slot="${boot_slot}", using slot A;
            setenv slot A;
            setenv boot_slot A;
            setenv ab_last_error invalid_boot_slot;
            run ab_note_config_failure;
        fi;
    fi

/* Switch logical slot and make it the next selected slot. */
ab_toggle_slot=
    if test "${slot}" = "A"; then
        setenv slot B;
    else
        setenv slot A;
    fi;
    setenv boot_slot ${slot}

/*
 * Build the Linux command line for the selected A/B slot.
 *
 * Boot-reliability hardening:
 *   panic=10          reboot 10 seconds after a kernel panic
 *   oops=panic        treat kernel oopses as panics
 *   hung_task_panic=1 panic if the kernel detects a hung task
 *
 * Together with bootcount + watchdog reset, these help failed trial boots
 * return to U-Boot so rollback can happen.
 */
ab_args=
    setenv bootargs console=${console} ${earlycon} root=PARTLABEL=${root_part_name} rootwait rw ab.slot=${slot} net.ifnames=0 panic=10 oops=panic hung_task_panic=1

/* Optional watchdog handoff. Keep booting even if watchdog start fails. */
ab_start_wdt=
    if test "${boot_watchdog}" = "1"; then
        echo Starting boot watchdog;
        wdt start 120000 || echo WARN: watchdog start failed;
    fi

/*
 * Resolve the selected logical slot by GPT labels and load kernel + DTB.
 * A -> BOOT_A + ROOTFS_A
 * B -> BOOT_B + ROOTFS_B
 */
ab_load=
    echo Loading slot ${slot};
    setenv boot_part_name BOOT_${slot};
    setenv root_part_name ROOTFS_${slot};
    if part number mmc ${mmcdev} ${boot_part_name} ab_boot_partnum; then
        if load mmc ${mmcdev}:${ab_boot_partnum} ${loadaddr} ${image}; then
            if load mmc ${mmcdev}:${ab_boot_partnum} ${fdt_addr_r} ${fdtfile}; then
                echo Loaded ${image} and ${fdtfile} from ${boot_part_name};
            else
                echo WARN: Cannot load DTB from ${boot_part_name};
                setenv ab_last_error missing_dtb_${slot};
                run ab_note_config_failure;
                test 1 = 0;
            fi;
        else
            echo WARN: Cannot load kernel from ${boot_part_name};
            setenv ab_last_error missing_kernel_${slot};
            run ab_note_config_failure;
            test 1 = 0;
        fi;
    else
        echo WARN: Cannot resolve GPT partition ${boot_part_name};
        setenv ab_last_error missing_boot_part_${slot};
        run ab_note_config_failure;
        test 1 = 0;
    fi

/* Try exactly one selected slot. If booti returns, Linux was not entered. */
ab_boot_once=
    if run ab_load; then
        run ab_args;
        run ab_start_wdt;
        echo Booting slot ${slot} root=${root_part_name};
        booti ${loadaddr} - ${fdt_addr_r};
        echo WARN: booti returned for slot ${slot};
        setenv ab_last_error booti_failed_${slot};
        run ab_note_failure;
        test 1 = 0;
    else
        test 1 = 0;
    fi

/* Final fallback after both A/B slots fail. */
ab_fallback_boot=
    echo WARN: Trying fixed single-slot fallback after A/B failure;
    run bsp_bootcmd

/*
 * Normal boot policy:
 *   1. select eMMC;
 *   2. normalize requested slot;
 *   3. try selected slot;
 *   4. try alternate slot;
 *   5. try fixed single-slot fallback.
 */
ab_boot=
    echo Running robust A/B bootcmd ...;
    if mmc dev ${mmcdev}; then
        run ab_select;
        if run ab_boot_once; then
            echo WARN: unexpected return after slot ${slot};
        else
            echo WARN: Slot ${slot} failed, trying alternate slot;
            run ab_toggle_slot;
            setenv upgrade_available 0;
            setenv bootcount 0;
            saveenv;
            if run ab_boot_once; then
                echo WARN: unexpected return after alternate slot ${slot};
            else
                echo WARN: Both A/B slots failed;
                setenv ab_last_error all_ab_slots_failed;
                run ab_note_failure;
                run ab_fallback_boot;
            fi;
        fi;
    else
        echo WARN: Cannot select mmc ${mmcdev};
        setenv slot none;
        setenv ab_last_error mmc_select_failed;
        run ab_note_failure;
        run ab_fallback_boot;
    fi

/*
 * Bootlimit rollback path. This runs as altbootcmd when bootcount > bootlimit.
 * It assumes Linux did not commit the pending slot, switches slots, clears the
 * trial state and re-enters the normal boot policy.
 */
ab_rollback=
    echo Bootlimit exceeded: rolling back from slot ${boot_slot};
    run ab_select;
    setenv ab_last_error bootlimit_rollback_${slot};
    run ab_note_failure;
    run ab_toggle_slot;
    setenv upgrade_available 0;
    setenv bootcount 0;
    saveenv;
    run ab_boot
